rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Products ───────────────────────────────────────────
    // Public read (storefront). No client-side writes — Admin SDK only.
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Orders ─────────────────────────────────────────────
    // No client access at all. Created/managed via Admin SDK (checkout API route).
    match /orders/{orderId} {
      allow read, write: if false;
    }

    // ─── Admins ─────────────────────────────────────────────
    // Authenticated users can read (for login validation).
    // No client writes — managed via Admin SDK only.
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── Messages (Contact Form) ────────────────────────────
    // Anyone can create a message (with field validation).
    // Authenticated admins can read. No client update/delete.
    match /messages/{messageId} {
      allow create: if true
        && request.resource.data.keys().hasOnly(['name', 'email', 'phone', 'content', 'isRead', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.email is string
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 2000
        && request.resource.data.isRead == false;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // ─── Activity Logs ──────────────────────────────────────
    // No client access at all. Written via Admin SDK only.
    match /activity_logs/{logId} {
      allow read, write: if false;
    }

    // ─── Default: Deny Everything ───────────────────────────
    // Any collection not explicitly listed above is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
